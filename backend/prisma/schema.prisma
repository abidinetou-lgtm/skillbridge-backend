generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Application roles. ADMIN users can moderate content and support users.
enum Role {
  USER
  ADMIN
}

// Keeps user accounts easy to moderate without deleting their data immediately.
enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// A match connects two users who may teach and learn from each other.
enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

// Conversations are restricted to users who are allowed to communicate.
enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

// Message status helps build read receipts and moderation tools later.
enum MessageStatus {
  SENT
  READ
  DELETED
}

// Reward keys are earned and spent through tracked transactions.
enum RewardTransactionType {
  EARNED
  SPENT
  ADJUSTED
  REFUNDED
}

// Teaching sessions track the real learning activity between matched users.
enum TeachingSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  bio          String?
  avatarUrl    String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)

  // Reward keys are stored on the user for fast balance reads.
  rewardKeys Int @default(0)

  // Skills this user can teach.
  teachingSkills UserSkill[]

  // Skills this user wants to learn.
  learningGoals LearningGoal[]

  // Matches are split into requester/receiver so Prisma can model both sides clearly.
  requestedMatches Match[] @relation("MatchRequester")
  receivedMatches  Match[] @relation("MatchReceiver")

  // Conversation ownership is limited to two participants for a restricted chat system.
  conversationsAsFirstUser  Conversation[] @relation("ConversationFirstUser")
  conversationsAsSecondUser Conversation[] @relation("ConversationSecondUser")
  messages                  Message[]

  rewardTransactions        RewardTransaction[]
  teachingSessionsAsTeacher TeachingSession[]   @relation("SessionTeacher")
  teachingSessionsAsLearner TeachingSession[]   @relation("SessionLearner")

  // Admin support fields make it possible to track who handled a case.
  adminSupportCreated RewardTransaction[] @relation("AdminRewardTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Skill {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  category    String?
  isActive    Boolean @default(true)

  // A skill can be taught by many users and requested in many learning goals.
  teachers      UserSkill[]
  learningGoals LearningGoal[]
  matches       Match[]
  sessions      TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model UserSkill {
  id                String  @id @default(uuid())
  userId            String
  skillId           String
  description       String?
  yearsOfExperience Int?
  isVerified        Boolean @default(false)

  // Delete a user's teaching skills when the user or skill is removed.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A user should only list the same teachable skill once.
  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isVerified])
}

model LearningGoal {
  id          String  @id @default(uuid())
  userId      String
  skillId     String
  description String?
  targetLevel String?
  isActive    Boolean @default(true)

  // Delete learning goals when the user or skill is removed.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isActive])
}

model Match {
  id          String      @id @default(uuid())
  requesterId String
  receiverId  String
  skillId     String?
  status      MatchStatus @default(PENDING)
  message     String?

  requester User   @relation("MatchRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User   @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  skill     Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  conversation     Conversation?
  teachingSessions TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent duplicate pending/active pairs for the same skill direction.
  @@unique([requesterId, receiverId, skillId])
  @@index([receiverId, status])
  @@index([requesterId, status])
  @@index([skillId])
}

model Conversation {
  id           String             @id @default(uuid())
  matchId      String             @unique
  firstUserId  String
  secondUserId String
  status       ConversationStatus @default(ACTIVE)

  // Conversations are tied to a match, which restricts chat to matched users.
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  firstUser  User      @relation("ConversationFirstUser", fields: [firstUserId], references: [id], onDelete: Cascade)
  secondUser User      @relation("ConversationSecondUser", fields: [secondUserId], references: [id], onDelete: Cascade)
  messages   Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstUserId])
  @@index([secondUserId])
  @@index([status])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  status         MessageStatus @default(SENT)
  readAt         DateTime?

  // Delete messages when a conversation is removed.
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([status])
}

model RewardTransaction {
  id          String                @id @default(uuid())
  userId      String
  adminId     String?
  amount      Int
  type        RewardTransactionType
  description String?

  // User receives or spends reward keys. Admin is optional for system-generated transactions.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminRewardTransactions", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([adminId])
  @@index([type])
}

model TeachingSession {
  id        String                @id @default(uuid())
  matchId   String
  teacherId String
  learnerId String
  skillId   String?
  status    TeachingSessionStatus @default(SCHEDULED)
  startsAt  DateTime
  endsAt    DateTime?
  notes     String?

  // Sessions connect the accepted match, teacher, learner, and optional skill.
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teacher User   @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  learner User   @relation("SessionLearner", fields: [learnerId], references: [id], onDelete: Cascade)
  skill   Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teacherId, startsAt])
  @@index([learnerId, startsAt])
  @@index([skillId])
  @@index([status])
}
