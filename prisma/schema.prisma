generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageStatus {
  SENT
  READ
  DELETED
}

enum RewardTransactionType {
  EARNED
  SPENT
  ADJUSTED
  REFUNDED
}

enum TeachingSessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_CONFIRMATION
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  bio          String?
  avatarUrl    String?
  availability String?    // JSON: { "Lundi_Matin": true, "Mardi_Soir": true, ... }
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  isEmailVerified Boolean @default(false)

  credits Int @default(120)

  teachingSkills UserSkill[]
  learningGoals  LearningGoal[]

  requestedMatches Match[] @relation("MatchRequester")
  receivedMatches  Match[] @relation("MatchReceiver")

  conversationsAsFirstUser  Conversation[] @relation("ConversationFirstUser")
  conversationsAsSecondUser Conversation[] @relation("ConversationSecondUser")
  messages                  Message[]

  rewardTransactions        RewardTransaction[]
  teachingSessionsAsTeacher TeachingSession[]   @relation("SessionTeacher")
  teachingSessionsAsLearner TeachingSession[]   @relation("SessionLearner")

  adminSupportCreated RewardTransaction[] @relation("AdminRewardTransactions")
  emailVerificationTokens EmailVerificationToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([isEmailVerified])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Skill {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  category    String?
  isActive    Boolean @default(true)

  teachers      UserSkill[]
  learningGoals LearningGoal[]
  matches       Match[]
  sessions      TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model UserSkill {
  id                String  @id @default(uuid())
  userId            String
  skillId           String
  description       String?
  yearsOfExperience Int?
  isVerified        Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isVerified])
}

model LearningGoal {
  id          String  @id @default(uuid())
  userId      String
  skillId     String
  description String?
  targetLevel String?
  isActive    Boolean @default(true)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isActive])
}

model Match {
  id          String      @id @default(uuid())
  requesterId String
  receiverId  String
  skillId     String?
  status      MatchStatus @default(PENDING)
  message     String?

  requester User   @relation("MatchRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User   @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  skill     Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  conversation     Conversation?
  teachingSessions TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId, skillId])
  @@index([receiverId, status])
  @@index([requesterId, status])
  @@index([skillId])
}

model Conversation {
  id           String             @id @default(uuid())
  matchId      String             @unique
  firstUserId  String
  secondUserId String
  status       ConversationStatus @default(ACTIVE)

  match      Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  firstUser  User      @relation("ConversationFirstUser", fields: [firstUserId], references: [id], onDelete: Cascade)
  secondUser User      @relation("ConversationSecondUser", fields: [secondUserId], references: [id], onDelete: Cascade)
  messages   Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstUserId])
  @@index([secondUserId])
  @@index([status])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  status         MessageStatus @default(SENT)
  readAt         DateTime?
  isSystem       Boolean       @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([status])
}

model RewardTransaction {
  id          String                @id @default(uuid())
  userId      String
  adminId     String?
  amount      Int
  type        RewardTransactionType
  description String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminRewardTransactions", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([adminId])
  @@index([type])
}

model TeachingSession {
  id               String                @id @default(uuid())
  matchId          String?
  teacherId        String
  learnerId        String
  skillId          String?
  status           TeachingSessionStatus @default(SCHEDULED)
  title            String
  description      String?
  jitsiRoomId      String                @unique
  startsAt         DateTime
  endsAt           DateTime?
  actualStartedAt  DateTime?
  actualEndedAt    DateTime?
  creditsReserved  Int                   @default(0)
  creditsConsumed  Int                   @default(0)
  notes            String?

  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  teacher User    @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  learner User    @relation("SessionLearner", fields: [learnerId], references: [id], onDelete: Cascade)
  skill   Skill?  @relation(fields: [skillId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teacherId, startsAt])
  @@index([learnerId, startsAt])
  @@index([skillId])
  @@index([status])
}
