generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageStatus {
  SENT
  READ
  DELETED
}

enum RewardTransactionType {
  EARNED
  SPENT
  ADJUSTED
  REFUNDED
}

enum TeachingSessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_CONFIRMATION
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  bio          String?
  avatarUrl    String?
  availability String?    // JSON: { "Lundi_Matin": true, "Mardi_Soir": true, ... }
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  sessionParticipations  SessionParticipant[] 
  notifications Notification[]

  credits Int @default(120)
  averageRating Float @default(0)
  totalRatings  Int   @default(0)

  teachingSkills UserSkill[]
  learningGoals  LearningGoal[]

  requestedMatches Match[] @relation("MatchRequester")
  receivedMatches  Match[] @relation("MatchReceiver")

  conversationsAsFirstUser  Conversation[] @relation("ConversationFirstUser")
  conversationsAsSecondUser Conversation[] @relation("ConversationSecondUser")
  messages                  Message[]
  passwordResetTokens       PasswordResetToken[]

  rewardTransactions        RewardTransaction[]
  teachingSessionsAsTeacher TeachingSession[]   @relation("SessionTeacher")
  teachingSessionsAsLearner TeachingSession[]   @relation("SessionLearner")
  ratingsGiven              SessionRating[]     @relation("RatingReviewer")
  ratingsReceived           SessionRating[]     @relation("RatingReviewedUser")

  adminSupportCreated RewardTransaction[] @relation("AdminRewardTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Skill {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  category    String?
  isActive    Boolean @default(true)

  teachers      UserSkill[]
  learningGoals LearningGoal[]
  matches       Match[]
  sessions      TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model UserSkill {
  id                String  @id @default(uuid())
  userId            String
  skillId           String
  description       String?
  yearsOfExperience Int?
  isVerified        Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isVerified])
}

model LearningGoal {
  id          String  @id @default(uuid())
  userId      String
  skillId     String
  description String?
  targetLevel String?
  isActive    Boolean @default(true)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId])
  @@index([isActive])
}

model Match {
  id          String      @id @default(uuid())
  requesterId String
  receiverId  String
  skillId     String?
  status      MatchStatus @default(PENDING)
  message     String?

  requester User   @relation("MatchRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User   @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  skill     Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  conversation     Conversation?
  teachingSessions TeachingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId, skillId])
  @@index([receiverId, status])
  @@index([requesterId, status])
  @@index([skillId])
}

model Conversation {
  id           String             @id @default(uuid())
  matchId      String?            @unique
  firstUserId  String
  secondUserId String
  status       ConversationStatus @default(ACTIVE)

  match      Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  firstUser  User      @relation("ConversationFirstUser", fields: [firstUserId], references: [id], onDelete: Cascade)
  secondUser User      @relation("ConversationSecondUser", fields: [secondUserId], references: [id], onDelete: Cascade)
  messages   Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstUserId])
  @@index([secondUserId])
  @@index([status])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  status         MessageStatus @default(SENT)
  readAt         DateTime?
  isSystem       Boolean       @default(false)
  type           MessageType @default(TEXT)
  fileUrl        String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([status])
}

enum MessageType {
  TEXT
  FILE 
  SYSTEM 
}

model RewardTransaction {
  id          String                @id @default(uuid())
  userId      String
  adminId     String?
  amount      Int
  type        RewardTransactionType
  description String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminRewardTransactions", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([adminId])
  @@index([type])
}

model TeachingSession {
  id               String                @id @default(uuid())
  matchId          String?
  teacherId        String
  learnerId        String
  skillId          String?
  status           TeachingSessionStatus @default(SCHEDULED)
  title            String
  description      String?
  jitsiRoomId      String                @unique
  startsAt         DateTime
  endsAt           DateTime?
  actualStartedAt  DateTime?
  actualEndedAt    DateTime?
  creditsReserved  Int                   @default(0)
  creditsConsumed  Int                   @default(0)
  notes            String?
  participants     SessionParticipant[]

  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  teacher User    @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  learner User    @relation("SessionLearner", fields: [learnerId], references: [id], onDelete: Cascade)
  skill   Skill?  @relation(fields: [skillId], references: [id], onDelete: SetNull)
  ratings SessionRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teacherId, startsAt])
  @@index([learnerId, startsAt])
  @@index([skillId])
  @@index([status])
}

model SessionRating {
  id             String @id @default(uuid())
  sessionId      String
  reviewerId     String
  reviewedUserId String
  rating         Int
  comment        String?

  session      TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewer     User            @relation("RatingReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedUser User            @relation("RatingReviewedUser", fields: [reviewedUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sessionId, reviewerId, reviewedUserId])
  @@index([reviewedUserId, createdAt])
  @@index([reviewerId])
  @@index([sessionId])
}

model SessionParticipant {
  id        String                 @id @default(uuid())
  sessionId String
  userId    String
  role      SessionParticipantRole

  session   TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

enum SessionParticipantRole {
  TEACHER
  LEARNER
}

model Notification {
  id        String @id @default(uuid())
  userId    String 

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType 
  message   String
  
  read Boolean @default(false)

  createdAt DateTime @default(now())
}

enum NotificationType {
  SESSION_BOOKED
  SESSION_ACCEPTED
  SESSION_REMINDER
}