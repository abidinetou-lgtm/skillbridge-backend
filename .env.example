PORT=5000
DATABASE_URL=postgresql://postgres:@localhost:5432/skillbridge
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5000
PASSWORD_RESET_URL=http://localhost:5173/reset-password
RESEND_API_KEY=
RESEND_FROM_EMAIL=SkillBridge <onboarding@resend.dev>
# Plusieurs origines séparées par virgule :
CORS_ORIGIN=http://localhost:5173,https://skillbridge.octilabs.com
# Mettre à true pour exiger la vérification email avant connexion (défaut : false)
REQUIRE_EMAIL_VERIFICATION=false
