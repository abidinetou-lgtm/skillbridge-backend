PORT=5000
DATABASE_URL=postgresql://postgres:@localhost:5432/skillbridge
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
# Plusieurs origines separees par virgule :
CORS_ORIGIN=http://localhost:5173,https://skillbridge.example.com
# Gmail SMTP — utilise un mot de passe d'application Google (16 caracteres, pas le mot de passe du compte)
GMAIL_USER=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Mettre a true pour exiger la verification email avant connexion (defaut : false)
REQUIRE_EMAIL_VERIFICATION=false
